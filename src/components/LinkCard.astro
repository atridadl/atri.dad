---
import { HiLink } from "react-icons/hi";
import { MdNavigateNext } from "react-icons/md";

export interface Props {
	title: string;
	href: string;
	external?: boolean;
}

const { title, href, external = false } = Astro.props;
---

<div class="card card-compact w-64 bg-primary shadow-xl">
	<div class="card-body text-base-100 flex flex-col">
		<h2 class="card-title text-base-100">{title}</h2>
		<slot />
		<div class="card-actions justify-end">
			{
				external ? (
					<a
						role="button"
						href={href}
						target="_blank"
						rel="noreferrer"
						aria-label={title}
						class="btn btn-circle btn-base-100"
					>
						<HiLink className="text-xl text-primary font-extrabold" />
					</a>
				) : (
					<a
						role="button"
						href={href}
						aria-label={title}
						class="btn btn-circle btn-base-100"
					>
						<MdNavigateNext className="text-xl text-primary font-extrabold" />
					</a>
				)
			}
		</div>
	</div>
</div>
